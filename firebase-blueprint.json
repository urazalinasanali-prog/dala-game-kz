{
  "entities": {
    "TradeInRequest": {
      "title": "Trade-In Request",
      "description": "A request from a user to trade in an old game for a discount on a new one.",
      "type": "object",
      "properties": {
        "gameTitle": {
          "type": "string",
          "description": "The name of the game."
        },
        "login": {
          "type": "string",
          "description": "Login or email for the account."
        },
        "password": {
          "type": "string",
          "description": "Password for the account."
        },
        "contactInfo": {
          "type": "string",
          "description": "User's contact information (e.g., phone or email)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the request was submitted."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "completed"],
          "description": "Current status of the trade-in request."
        }
      },
      "required": ["gameTitle", "login", "password", "contactInfo", "createdAt", "status"]
    }
  },
  "firestore": {
    "/tradeInRequests/{requestId}": {
      "schema": "TradeInRequest",
      "description": "Collection of trade-in requests."
    }
  }
}
