rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tradeInRequests
    // Document ID: {requestId}
    // Fields:
    //   - gameTitle: string (required) - The title of the game
    //   - login: string (required) - Account login/email
    //   - password: string (required) - Account password
    //   - contactInfo: string (required) - User's contact info
    //   - createdAt: timestamp (required) - Submission time
    //   - status: string (required, enum: ['pending', 'reviewed', 'completed']) - Status
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "urazalinasanali@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidTradeInRequest(data) {
      return data.keys().hasAll(['gameTitle', 'login', 'password', 'contactInfo', 'createdAt', 'status']) &&
             data.gameTitle is string && data.gameTitle.size() > 0 && data.gameTitle.size() < 500 &&
             data.login is string && data.login.size() > 0 && data.login.size() < 500 &&
             data.password is string && data.password.size() > 0 && data.password.size() < 500 &&
             data.contactInfo is string && data.contactInfo.size() > 0 && data.contactInfo.size() < 500 &&
             data.createdAt is timestamp &&
             data.status in ['pending', 'reviewed', 'completed'];
    }

    match /tradeInRequests/{requestId} {
      // Anyone can submit a request
      allow create: if isValidTradeInRequest(request.resource.data) && 
                      request.resource.data.status == 'pending';
      
      // WARNING: Public read access is a major security risk, especially for sensitive data like passwords.
      // Anyone with access to the database can now read all trade-in requests.
      allow read: if true;
      
      // Only admin can update or delete requests
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
